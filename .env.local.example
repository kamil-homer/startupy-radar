# Klucz API Anthropic — wymagany do generowania pomysłów na posty.
# Pobierz z https://console.anthropic.com/  → Settings → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# Buffer (nowy GraphQL API) — do wysyłania draftów na LinkedIn.
# Klucz generuje WŁAŚCICIEL organizacji w ustawieniach Buffer.
BUFFER_API_KEY=

# ID kanału LinkedIn w Buffer. Po ustawieniu BUFFER_API_KEY odpal:
#   curl http://localhost:3000/api/buffer
# zwróci listę kanałów (id, name, service) — skopiuj id LinkedIna tutaj.
BUFFER_CHANNEL_ID=
